# Secrets & tokens — never commit these
.env
*.json
!frontend/vercel.json

# Keep data/ folder but not its contents
data/*
!data/.gitkeep

# YOLO model weights — too large for git
*.pt

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Node modules
node_modules/
**/node_modules/

# Vite build output
dist/
**/dist/

# Logs
*.log
uvicorn*.log
gettyimages*.jpg
OCR.py
test_*.py
